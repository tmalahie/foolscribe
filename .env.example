# foolscribe — template des variables d'environnement.
# Copier en `.env` et renseigner les valeurs (le vrai .env n'est pas commité).

# --- App ---
# PORT=3001
JWT_SECRET=
# Liste blanche des membres (emails Google, séparés par des virgules)
ALLOWED_EMAILS=
# Modèle de raisonnement de la pipeline (défaut : claude-opus-4-8)
# REASONING_MODEL=claude-opus-4-8

# --- OVH Object Storage (S3-compatible) ---
S3_ENDPOINT=https://s3.eu-west-par.io.cloud.ovh.net
S3_REGION=eu-west-par
S3_BUCKET=foolscribe
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Pipeline d'analyse ---
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=

# --- Google (Drive + Sign-In) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Générer via : npm run get-refresh-token (voir README)
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- MySQL ---
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
